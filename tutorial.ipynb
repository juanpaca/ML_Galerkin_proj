    "#   ds[\"train\"][\"xi\"]         →  {pe, rho, xi, b, db}\n",
    "#   ds[\"val\"][...]            →  validation split\n",
    "#   ds[\"test\"][...]           →  test split\n",
    "\n",
    "xi_full = ds[\"train\"][\"constant\"][\"xi\"]  # original FD grid\n",
    "print(f\"xi grid: {xi_full.shape[0]} points\")"
